    "import pandas as pd\n",
    "\n",
    "# Маппінг NOAA індексів на українські назви (за українською абеткою)\n",
    "REGION_NAMES = {\n",
    "    1:  (24, 'Вінницька'),\n",
    "    2:  (25, 'Волинська'),\n",
    "    3:  (26, 'Дніпропетровська'),\n",
    "    4:  (27, 'Донецька'),\n",
    "    5:  (10, 'Житомирська'),\n",
    "    6:  (11, 'Закарпатська'),\n",
    "    7:  (12, 'Запорізька'),\n",
    "    8:  (13, 'Івано-Франківська'),\n",
    "    9:  (14, 'Київська'),\n",
    "    10: (15, 'Кіровоградська'),\n",
    "    11: (16, 'Луганська'),\n",
    "    12: (17, 'Львівська'),\n",
    "    13: (18, 'Миколаївська'),\n",
    "    14: (19, 'Одеська'),\n",
    "    15: (20, 'Полтавська'),\n",
    "    16: (21, 'Рівненська'),\n",
    "    17: (22, 'Сумська'),\n",
    "    18: (23, 'Тернопільська'),\n",
    "    19: (1,  'Харківська'),\n",
    "    20: (2,  'Херсонська'),\n",
    "    21: (3,  'Хмельницька'),\n",
    "    22: (4,  'Черкаська'),\n",
    "    23: (5,  'Чернівецька'),\n",
    "    24: (6,  'Чернігівська'),\n",
    "    25: (7,  'Республіка Крим'),\n",
    "    26: (8,  'м. Севастополь'),\n",
    "    27: (9,  'м. Київ'),\n",
    "}\n",
    "\n",
    "def load_vhi_data(data_dir=\"data\"):\n",
    "    frames = []\n",
    "    for fname in os.listdir(data_dir):\n",
    "        if not fname.endswith(\".csv\"):\n",
    "            continue\n",
    "        \n",
    "        province_id = int(fname.split(\"_\")[1])\n",
    "        filepath = os.path.join(data_dir, fname)\n",
    "        \n",
    "        df = pd.read_csv(filepath, header=1, on_bad_lines='skip')\n",
    "        df.columns = df.columns.str.strip()\n",
    "        \n",
    "        # Залишаємо потрібні стовпці\n",
    "        df = df[['Year', 'Week', 'SMN', 'SMT', 'VCI', 'TCI', 'VHI']].copy()\n",
    "        \n",
    "        # Видаляємо рядки з пропусками або -1\n",
    "        df = df[df['VHI'] != -1].dropna()\n",
    "        df['Year'] = df['Year'].astype(int)\n",
    "        df['Week'] = df['Week'].astype(int)\n",
    "        \n",
    "        # Додаємо індекс та назву області\n",
    "        ua_index, ua_name = REGION_NAMES[province_id]\n",
    "        df['province_id'] = ua_index\n",
    "        df['province_name'] = ua_name\n",
    "        \n",
    "        frames.append(df)\n",
    "    \n",
    "    return pd.concat(frames, ignore_index=True)\n",
    "\n",
    "df = load_vhi_data()\n",
    "print(df.shape)\n",
    "df.head(10)"
   ]
