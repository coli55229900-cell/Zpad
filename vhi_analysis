    "def download_vhi_data(data_dir=\"data\"):\n",
    "    os.makedirs(data_dir, exist_ok=True)\n",
    "    \n",
    "    for province_id in range(1, 28):\n",
    "        # Перевірка чи файл вже існує\n",
    "        existing = [f for f in os.listdir(data_dir) if f\"province_{province_id}_\" in f]\n",
    "        if existing:\n",
    "            print(f\"Область {province_id} вже завантажена: {existing[0]}\")\n",
    "            continue\n",
    "        \n",
    "        url = f\"https://www.star.nesdis.noaa.gov/smcd/emb/vci/VH/get_TS_admin.php?country=UKR&provinceID={province_id}&year1=1981&year2=2024&type=Mean\"\n",
    "        \n",
    "        timestamp = datetime.now().strftime(\"%Y%m%d_%H%M%S\")\n",
    "        filename = f\"{data_dir}/province_{province_id}_{timestamp}.csv\"\n",
    "        \n",
    "        try:\n",
    "            urllib.request.urlretrieve(url, filename)\n",
    "            print(f\"✅ Завантажено область {province_id}\")\n",
    "        except Exception as e:\n",
    "            print(f\"❌ Помилка для області {province_id}: {e}\")\n",
    "\n",
    "download_vhi_data()"
   ]
