    "# 3.3 Екстремуми, середнє та медіана\n",
    "def vhi_stats(df, province_ids, year_from, year_to):\n",
    "    subset = df[\n",
    "        (df['province_id'].isin(province_ids)) & \n",
    "        (df['Year'] >= year_from) & \n",
    "        (df['Year'] <= year_to)\n",
    "    ]\n",
    "    stats = subset.groupby('province_name')['VHI'].agg(\n",
    "        Мінімум='min',\n",
    "        Максимум='max',\n",
    "        Середнє='mean',\n",
    "        Медіана='median'\n",
    "    ).round(2)\n",
    "    print(f\"Статистика VHI для областей {province_ids} за {year_from}-{year_to}:\")\n",
    "    return stats\n",
    "\n",
    "vhi_stats(df, [15, 1, 24], 2000, 2010)"
   ]
