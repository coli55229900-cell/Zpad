    "        df['Week'] = pd.to_numeric(df['Week'], errors='coerce')\n",
    "        df['VCI'] = pd.to_numeric(df['VCI'], errors='coerce')\n",
    "        df['TCI'] = pd.to_numeric(df['TCI'], errors='coerce')\n",
