    "# 3.2 Ряд VHI за діапазон років для вказаних областей\n",
    "def vhi_by_regions_years(df, province_ids, year_from, year_to):\n",
    "    result = df[\n",
    "        (df['province_id'].isin(province_ids)) & \n",
    "        (df['Year'] >= year_from) & \n",
    "        (df['Year'] <= year_to)\n",
    "    ][['Year','Week','VHI','province_id','province_name']]\n",
    "    print(f\"VHI для областей {province_ids} за {year_from}-{year_to}:\")\n",
    "    return result\n",
    "\n",
    "vhi_by_regions_years(df, [15, 1], 2000, 2005)"
   ]
